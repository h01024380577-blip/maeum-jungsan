{
  "entities": {
    "PushSubscription": {
      "title": "Push Subscription",
      "description": "Web Push subscription object for a user",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The unique ID of the user"
        },
        "endpoint": {
          "type": "string",
          "description": "The push service endpoint URL"
        },
        "keys": {
          "type": "object",
          "properties": {
            "p256dh": {
              "type": "string"
            },
            "auth": {
              "type": "string"
            }
          },
          "required": ["p256dh", "auth"]
        },
        "createdAt": {
          "type": "number",
          "description": "Timestamp when the subscription was created"
        }
      },
      "required": ["userId", "endpoint", "keys", "createdAt"]
    },
    "Contact": {
      "title": "Contact",
      "description": "A contact in the user's network",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "kakaoId": { "type": "string" },
        "relation": { "type": "string" },
        "avatar": { "type": "string" },
        "userId": { "type": "string" }
      },
      "required": ["id", "name", "relation", "userId"]
    },
    "EventEntry": {
      "title": "Event Entry",
      "description": "A record of a gift given or received at an event",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "contactId": { "type": "string" },
        "eventType": { "type": "string", "enum": ["wedding", "funeral", "birthday", "other"] },
        "type": { "type": "string", "enum": ["INCOME", "EXPENSE"] },
        "date": { "type": "string", "format": "date" },
        "location": { "type": "string" },
        "targetName": { "type": "string" },
        "amount": { "type": "number" },
        "relation": { "type": "string" },
        "customEventName": { "type": "string" },
        "createdAt": { "type": "number" },
        "userId": { "type": "string" }
      },
      "required": ["id", "contactId", "eventType", "type", "date", "amount", "userId"]
    }
  },
  "firestore": {
    "/subscriptions/{subscriptionId}": {
      "schema": "PushSubscription",
      "description": "Store web push subscriptions"
    },
    "/contacts/{contactId}": {
      "schema": "Contact",
      "description": "Store user contacts"
    },
    "/entries/{entryId}": {
      "schema": "EventEntry",
      "description": "Store event entries"
    }
  }
}
